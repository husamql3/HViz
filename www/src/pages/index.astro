---
import "../global.css";
import Layout from "@/layouts/Layout.astro";
import { Input } from "@/components/ui/input";
import { Button } from "@/components/ui/button";
import { cn } from "@/lib/utils";
import { ROADMAP } from "@/lib/roadmap";
---

<Layout>
  <div
    class="bg-zinc-950 min-h-dvh py-4 md:py-14 font-roboto-mono text-zinc-50 flex flex-col justify-center items-center max-w-3xl mx-auto"
  >
    <div class="text-center">
      <h1 class="text-6xl pb-2 border-b-4 mb-2 border-green-700">hviz</h1>
      <p class="text-neutral-300 text-xs">ERD generator for your database</p>
    </div>

    <div class="flex md:flex-row flex-col gap-6 pt-14 px-4 pb-14">
      <div class="flex flex-col gap-4">
        <p class="border-l-4 pl-2 text-lg border-green-700">join waitlist</p>
        <p class="text-xs">
          hviz is in active development and not yet production-ready. Sign up to
          stay updated!
        </p>
        <Input placeholder="your@email.com" variant="lg" />
        <Button size="lg" className="hover:bg-green-700 transition-colors">
          join waitlist
        </Button>
      </div>

      <div class="flex flex-col gap-4">
        <p class="border-l-4 pl-2 text-lg border-green-700">roadmap</p>
        <p class="text-xs">
          Our progress toward a robust ERD generator. Here's what's in the
          works:
        </p>
        <div class="flex flex-col gap-4">
          {
            ROADMAP.map((item) => (
              <div class="flex flex-col gap-1">
                <div class="flex flex-row gap-2 items-center">
                  <div
                    class={cn(
                      "w-2 h-2 rounded-full",
                      item.status === "in progress" || item.status === "done"
                        ? "bg-green-700"
                        : "bg-neutral-500"
                    )}
                  />
                  <p class="text-lg">{item.title}</p>
                </div>

                <p class="text-sm text-neutral-400">{item.subtitle}</p>

                {item.subFeatures && item.subFeatures.length > 0 && (
                  <ul class="flex flex-row gap-1 flex-wrap">
                    {item.subFeatures.map((subFeature, index) => {
                      return (
                        <li class="flex items-center flex-row gap-0 text-sm">
                          <span
                            class={cn(
                              "text-neutral-500",
                              subFeature.status === "in progress" ||
                                subFeature.status === "done"
                                ? "text-green-700"
                                : "text-neutral-500"
                            )}
                          >
                            {subFeature.title}
                          </span>
                          {item.subFeatures &&
                            index < item.subFeatures.length - 1 && (
                              <span class="text-neutral-500">,</span>
                            )}
                        </li>
                      );
                    })}
                  </ul>
                )}

                <p
                  class={cn(
                    "text-xs",
                    item.status === "in progress" || item.status === "done"
                      ? "text-green-700"
                      : "text-neutral-500"
                  )}
                >
                  {item.status}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <hr class="w-full border-zinc-800" />

    <p class="text-xs text-zinc-300 pt-6">
      © 2025 hviz — <a
        href="https://x.com/husamql3"
        class="underline hover:text-green-700 transition-colors">@husamql3</a
      >
    </p>
  </div>
</Layout>
