{
  "name": "hviz",
  "version": "1.1.8",
  "type": "module",
  "description": "CLI tool for visualizing your database schema",
  "license": "MIT",
  "author": {
    "name": "husamql3",
    "url": "https://x.com/husamql3",
    "email": "devhsmq@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/husamql3/hviz",
    "directory": "packages/core"
  },
  "homepage": "https://www.hviz.tech",
  "bugs": {
    "url": "https://github.com/husamql3/hviz/issues"
  },
  "keywords": [
    "erd",
    "database",
    "visualization",
    "prisma",
    "drizzle",
    "schema",
    "cli"
  ],
  "bin": {
    "hviz": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "view-build",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "NODE_ENV=development bun run src/index.ts",
    "build": "tsup",
    "prepublishOnly": "echo 'Building for publish...' && bun run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@dbml/core": "^3.15.0-alpha.0",
    "@hono/node-server": "^1.19.5",
    "@prisma/internals": "^6.17.1",
    "commander": "^14.0.1",
    "drizzle-dbml-generator": "^0.10.0",
    "hono": "^4.10.1",
    "open": "^10.2.0",
    "pg": "^8.16.3",
    "picocolors": "^1.1.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.27"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "tsup": "^8.5.0",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "@vitest/coverage-v8": "3.2.4",
    "vitest": "^3.2.4"
  }
}