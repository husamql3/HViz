{
  "name": "hviz",
  "type": "module",
  "private": true,
  "author": {
    "name": "husamql3",
    "url": "https://x.com/husamql3",
    "email": "devhsmq@gmail.com"
  },
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "www"
  ],
  "scripts": {
    "dev:www": "bun run --filter='@hviz/www' dev",
    "dev:core": "bun run --cwd packages/core dev",
    "build": "bun run build:view && bun run build:core",
    "build:view": "bun run --cwd packages/view build",
    "build:core": "bun run --cwd packages/core build && bun run scripts/post-build.ts",
    "build:www": "bun run --cwd www build",
    "test": "bun run --filter='*' test",
    "check": "bunx biome check --write --verbose --unsafe",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.6",
    "@changesets/cli": "^2.29.7",
    "@types/bun": "latest",
    "tsup": "^8.3.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20.x",
    "bun": ">=1.2.19"
  },
  "packageManager": "bun@1.2.19"
}